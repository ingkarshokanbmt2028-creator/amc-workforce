generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LicenseStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  PENDING
}

enum ShiftType {
  MORNING
  AFTERNOON
  DAY
  PM_SHIFT
  NIGHT
  LATE
  ON_CALL
  OFF
  ANNUAL_LEAVE
  MATERNITY_LEAVE
  SICK_LEAVE
}

enum RosterStatus {
  DRAFT
  PUBLISHED
  LOCKED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_DEPARTURE
  PARTIAL
  ON_LEAVE
}

model Department {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String     @unique
  employees Employee[]
  rosters   Roster[]
}

model Employee {
  id                   String       @id @default(cuid())
  staffId              String       @unique
  name                 String
  departmentId         String
  department           Department   @relation(fields: [departmentId], references: [id])
  position             String
  location             String       @default("ACCRA")
  status               String       @default("ACTIVE")
  biotimeEmpCode       String?
  employeeType         String       @default("PERMANENT") // PERMANENT | LOCUM | CONTRACT
  expectedMonthlyHours Float        @default(180)
  hourlyRate           Float?       // GH₵ per hour — used for locum/contract cost calculation
  monthlySalary        Float?       // GH₵ per month — used for permanent staff cost calculation
  rosterSlots          RosterSlot[]
  attendances          Attendance[]
  leaveBalances        LeaveBalance[]
  creditBalances       CreditBalance[]
  licenses             License[]
}

model Roster {
  id           String       @id @default(cuid())
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id])
  month        Int
  year         Int
  status       RosterStatus @default(DRAFT)
  publishedAt  DateTime?
  publishedBy  String?
  createdBy    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  slots        RosterSlot[]

  @@unique([departmentId, month, year])
}

model RosterSlot {
  id           String      @id @default(cuid())
  rosterId     String
  roster       Roster      @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id])
  date         DateTime    @db.Date
  shiftType    ShiftType
  startTime    String?
  endTime      String?
  plannedHours Float?
  location     String?
  isEmergency  Boolean     @default(false)
  coveringFor  String?
  changedBy    String?
  changedAt    DateTime?
  changeReason String?
  notes        String?
  createdAt    DateTime    @default(now())
  attendance   Attendance?

  @@index([employeeId, date])
}

model Attendance {
  id                    String           @id @default(cuid())
  employeeId            String
  employee              Employee         @relation(fields: [employeeId], references: [id])
  rosterSlotId          String?          @unique
  rosterSlot            RosterSlot?      @relation(fields: [rosterSlotId], references: [id])
  date                  DateTime         @db.Date
  clockIn               DateTime?
  clockOut              DateTime?
  totalHours            Float?
  scheduledIn           String?
  scheduledOut          String?
  lateMinutes           Int?
  earlyDepartureMinutes Int?
  status                AttendanceStatus @default(PRESENT)
  isManualOverride      Boolean          @default(false)
  overrideBy            String?
  overrideReason        String?
  notes                 String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
}

model BiotimeSyncLog {
  id               String   @id @default(cuid())
  syncedAt         DateTime @default(now())
  recordsFetched   Int
  recordsProcessed Int
  errors           String?
  fromDate         DateTime
  toDate           DateTime
}

model LeaveBalance {
  id                String   @id @default(cuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id])
  fiscalYear        String   // e.g. "2025-2026"
  annualEntitlement Int      @default(0)
  openingBalance    Int      @default(0)
  totalAvailable    Int      @default(0)
  daysTaken         Int      @default(0)
  daysRemaining     Int      @default(0)
  leaveNotes        String?  // raw leave date text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([employeeId, fiscalYear])
}

model CreditBalance {
  id               String   @id @default(cuid())
  employeeId       String
  employee         Employee @relation(fields: [employeeId], references: [id])
  month            Int      // 1–12
  year             Int
  initialCredit    Float    @default(1500)
  deductions       Float    @default(0)
  overtimeCredits  Float    @default(0)
  finalCredit      Float    @default(1500)
  totalHoursWorked Float    @default(0)
  targetHours      Float    @default(250)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([employeeId, month, year])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  reason     String?
  userId     String?
  createdAt  DateTime @default(now())
}

model License {
  id         String        @id @default(cuid())
  employeeId String
  employee   Employee      @relation(fields: [employeeId], references: [id])
  type       String        // e.g. "MEDICAL_LICENSE", "BLS_CPR", "FIRE_SAFETY", "NURSING_LICENSE"
  licenseNo  String?
  issuedBy   String?
  issuedAt   DateTime?
  expiresAt  DateTime?     // null = no expiry required
  status     LicenseStatus @default(ACTIVE)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([employeeId])
  @@index([expiresAt])
  @@index([status])
}
